{
  "name": "tanstack-start-template",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "clean": "bunx rimraf .output .vite node_modules .tanstack src/routeTree.gen.ts coverage test-results playwright-report",
    "dev": "cross-env NODE_OPTIONS=--import=./instrument.server.mjs vite dev --port 3000",
    "build": "vite build",
    "build:docker": "docker build -t tanstack-start-template .",
    "preview": "vite preview",
    "start": "bun --import ./instrument.server.mjs .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "load-env": "dotenv -e .env --",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "auth:generate": "bunx auth@latest generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run load-env drizzle-kit migrate",
    "db:push": "bun run load-env drizzle-kit push",
    "db:pull": "bun run load-env drizzle-kit pull",
    "db:studio": "bun run load-env drizzle-kit studio",
    "codegen": "playwright codegen",
    "test:unit": "bun run vitest run",
    "test:e2e": "bun run playwright test",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@better-auth/passkey": "^1.6.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@logtape/logtape": "^2.0.6",
    "@logtape/sentry": "^2.0.6",
    "@opentelemetry/instrumentation-pg": "^0.68.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/tanstackstart-react": "^10.51.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-form-start": "^1.29.1",
    "@tanstack/react-query": "^5.100.8",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.59",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.167.32",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "1.14.0",
    "next-themes": "^0.4.6",
    "nitro": "^3.0.260429-beta",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form-devtools": "^0.2.22",
    "@tanstack/react-query-devtools": "^5.100.8",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "26",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/instrumentation": "0.214.0"
  },
  "packageManager": "bun@1.3.13"
}
